FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    git jq curl ca-certificates ripgrep procps util-linux \
    && rm -rf /var/lib/apt/lists/*

# #19対策: ホストのUID/GIDに合わせてユーザーを作成（Linux環境で必要）
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN groupadd -g ${GROUP_ID} reviewer || true && \
    useradd -m -s /bin/bash -u ${USER_ID} -g ${GROUP_ID} reviewer
USER reviewer
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/reviewer/.local/bin:${PATH}"

WORKDIR /home/reviewer
RUN mkdir -p /home/reviewer/claude-reviews /tmp/claude-review /tmp/claude-review-locks /tmp/claude-review-input

# #10対策: コンテナ内UIDとホスト側UIDが異なるためGitのsafe.directoryを設定
RUN git config --global --add safe.directory '*'

HEALTHCHECK --interval=60s --timeout=10s \
    CMD claude --version || exit 1
